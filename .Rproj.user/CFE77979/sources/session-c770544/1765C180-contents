#' Extract posterior samples
#'
#' Extract posterior draws from a fitted \code{BayesDiffIRT} model.
#'
#' @param object A fitted model object of class \code{BayesDiffIRTfit}.
#' @param parameters Optional character vector specifying which parameters to
#'   extract. If \code{NULL}, samples for all parameters are returned. Parameter
#'   names can refer to scalar parameters, vector parameters, or individual
#'   indexed parameters, depending on how they are stored in the fitted Stan
#'   model. For example, \code{"theta"} extracts all person-specific
#'   \code{theta} parameters, whereas \code{"theta[1]"} extracts only the first
#'   one.
#' @param ... Currently unused.
#'
#' @return A \code{draws_df} object containing posterior samples.
#'
#' @examples
#' \dontrun{
#' samples <- extractSamples(fit)
#' theta.samples <- extractSamples(fit, parameters = "theta")
#' selected.samples <- extractSamples(fit, parameters = c("theta", "gamma", "a"))
#' }
#'
#' @export
extractSamples <- function(object, parameters = NULL, ...) {
  UseMethod("extractSamples")
}

#' @rdname extractSamples
#' @method extractSamples BayesDiffIRTfit
#' @export
extractSamples.BayesDiffIRTfit <- function(object, parameters = NULL, ...) {

  if (!is.null(parameters)) {
    if (!is.character(parameters)) {
      stop("'parameters' must be a character vector.", call. = FALSE)
    }

    if (length(parameters) < 1L) {
      stop("'parameters' must contain at least one parameter name.", call. = FALSE)
    }
  }

  posterior::as_draws_df(
    object$fit$draws(variables = parameters)
  )
}
