#' @title
#' Plot posterior draws from a fitted BayesDiffIRT model

#' @description
#' Plot posterior summaries, marginal posterior densities, or trace plots for
#' selected parameters of a fitted BayesDiffIRT model.
#'
#' @param x A fitted model object of class \code{BayesDiffIRTfit}, typically
#'   returned by \code{\link{fitBayesDiffIRT}}.
#' @param parameter Character string. Name of the parameter to plot. Must be one
#'   of \code{"theta"}, \code{"gamma"}, \code{"nu"}, \code{"a"},
#'   \code{"tnd"}, \code{"omega_theta"}, \code{"omega_gamma"},
#'   \code{"s_delta"}, or \code{"s_beta"}. Person-specific and item-specific
#'   parameters can be subset with \code{index}.
#' @param type Character string. Type of plot to produce. Must be one of
#'   \code{"interval"}, \code{"density"}, or \code{"trace"}.
#'   \code{"interval"} displays posterior means with 50\% and 95\% credible
#'   intervals. \code{"density"} displays marginal posterior densities.
#'   \code{"trace"} displays MCMC trace plots by chain.
#' @param index Optional integer vector. Indices of person-specific or
#'   item-specific parameters to plot. For example, \code{index = 1:5} with
#'   \code{parameter = "theta"} plots \code{theta[1]} to \code{theta[5]}.
#'   If \code{NULL}, all matching parameters are extracted and the plotted
#'   parameters are limited by \code{nmax}.
#' @param nmax Integer. Maximum number of indexed parameters to display when
#'   \code{index = NULL}. Defaults to \code{15}. Ignored when \code{index} is
#'   supplied.
#' @param ... Additional arguments passed to the generic \code{plot()} method.
#'   Currently unused.
#'
#' @return Invisibly returns the \code{\link[ggplot2]{ggplot}} object used to
#'   create the plot.
#'
#' @examples
#' data("bayesDiffIRTexample")
#' \dontrun{
#'
#' fit <- fitBayesDiffIRT(bayesDiffIRTexample)
#'
#' # Interval plot for the first 10 theta parameters
#' plot(fit, parameter = "theta", type = "interval", index = 1:10)
#'
#' # Posterior densities for item parameter nu
#' plot(fit, parameter = "nu", type = "density", index = 1:5)
#'
#' # Trace plot for omega_theta
#' plot(fit, parameter = "omega_theta", type = "trace")
#' }
#'
#' @seealso
#' \code{\link{fitBayesDiffIRT}},
#' \code{\link[ggplot2:ggplot]{ggplot2::ggplot}}
#'
#' @import ggplot2
#' @importFrom posterior as_draws_df
#' @importFrom rlang .data
#'
#' @author
#' Manuel Rausch, \email{manuel.rausch@@aau.at}

#' @method plot BayesDiffIRTfit

#' @export
plot.BayesDiffIRTfit <-
  function(x,
           type = c("interval", "density", "trace"),
           parameter = c("theta", "gamma", "nu", "a", "tnd",
                         "omega_theta", "omega_gamma", "s_delta", "s_beta"),
           index = NULL,
           nmax = 15,
           ...) {

    parameter <- match.arg(parameter)
    type <- match.arg(type)

    scalarPars <- c("omega_theta", "omega_gamma", "s_delta", "s_beta")

    if (!is.null(index) && parameter %in% scalarPars) {
      stop("index can only be used for indexed parameters.", call. = FALSE)
    }

    # Construct Stan parameter names
    if (!is.null(index)) {
      pars <- paste0(parameter, "[", index, "]")
    } else {
      pars <- parameter
    }

    # Extract draws
    drawsAll <- as.data.frame(
      posterior::as_draws_df(x$fit$draws(pars)))

    # Remove posterior metadata columns
    metadataCols <- c(".chain", ".iteration", ".draw")
    parameterCols <- setdiff(names(drawsAll), metadataCols)

    # If no explicit index was supplied, limit to first nmax parameters
    if (is.null(index)) {
      parameterCols <- utils::head(parameterCols, nmax)
    }

    draws <- drawsAll[, parameterCols, drop = FALSE]

    # Convert to long format
    drawsLong <- utils::stack(draws)

    if (type == "interval") {

      summaryDf <- stats::aggregate(
        drawsLong["values"],by = list(ind = drawsLong$ind),
        FUN = mean)
      names(summaryDf)[2] <- "mean"

      summaryDf$lo50 <- stats::aggregate(
        drawsLong["values"],by = list(ind = drawsLong$ind),
        FUN = function(x) stats::quantile(x, 0.25))$values

      summaryDf$hi50 <- stats::aggregate(
        drawsLong["values"],by = list(ind = drawsLong$ind),
        FUN = function(x) stats::quantile(x, 0.75))$values

      summaryDf$lo95 <- stats::aggregate(
        drawsLong["values"],by = list(ind = drawsLong$ind),
        FUN = function(x) stats::quantile(x, 0.025))$values

      summaryDf$hi95 <- stats::aggregate(
        drawsLong["values"],by = list(ind = drawsLong$ind),
        FUN = function(x) stats::quantile(x, 0.975))$values

      p <- ggplot2::ggplot(
        summaryDf, ggplot2::aes(x = .data[["ind"]], y = .data[["mean"]])) +
        ggplot2::geom_linerange(
          ggplot2::aes(ymin = .data[["lo95"]], ymax = .data[["hi95"]]),
          linewidth = 0.4) +
        ggplot2::geom_linerange(
          ggplot2::aes(ymin = .data[["lo50"]], ymax = .data[["hi50"]]),
          linewidth = 1.2) +
        ggplot2::geom_point(size = 2,shape = 21,
                            fill = grDevices::rgb(52, 108, 131, maxColorValue = 255)) +
        ggplot2::coord_flip() +
        ggplot2::labs(x = NULL, y = "Parameter value",
          subtitle = "Mean with 50% and 95% credible intervals"
        ) +
        ggplot2::theme_classic()
      base::print(p)
      return(invisible(p))
    }

    if (type == "density") {

      p <- ggplot2::ggplot(
        drawsLong, ggplot2::aes(x = .data[["values"]], fill = .data[["ind"]])) +
        ggplot2::geom_density(alpha=.2) +
        ggplot2::labs(x = "Parameter value",y = "density",
                      subtitle = "Posterior distribution",
                      fill = NULL) +
        ggplot2::theme_classic()
      base::print(p)
      return(invisible(p))
    }

    if (type == "trace"){
      drawsDf <- as.data.frame(drawsAll)
      drawsLong <- data.frame(
        drawsDf[rep(seq_len(nrow(drawsDf)),
                    times = length(parameterCols)),  metadataCols, drop = FALSE],
        parameter = rep(parameterCols, each = nrow(drawsDf)),
        value = unlist(drawsDf[parameterCols], use.names = FALSE),
        row.names = NULL#
      )

      # Convert to long format
      p <- ggplot2::ggplot(drawsLong, ggplot2::aes(x=.data[[".iteration"]],
                                 y=.data[["value"]],
                                 color=factor(.data[[".chain"]]))) +
        ggplot2::geom_line()
      if(length(unique(drawsLong$parameter))> 1){
        p <- p + ggplot2::facet_wrap(stats::as.formula("~ parameter"),
                            nrow = ceiling(sqrt(length(unique(drawsLong$parameter)))),
                            ncol = ceiling(sqrt(length(unique(drawsLong$parameter)))))
      }
      p <- p + ggplot2::labs(
        x = "Iteration",y = "Parameter value",
        color = NULL) +
        ggplot2::theme_classic()

      base::print(p)
      return(invisible(p))

    }

    stop("Plot type not implemented yet.", call. = FALSE)
  }
