library(diffIRT)
load("/dev/Tests.RData")
data(extraversion)
x=extraversion[,1:10]
rt=extraversion[,11:20]

# fit an unconstrained D-diffusion model
# item-specific a, item-specific v, item-specific Ter
# poupulation specific parameters: omega(gamma), omega [theta]
# Why is there an item-specific Ter??? Should Ter not be a person-parameter?

diffIRT_fit <-  diffIRT(rt, x, model="D")

fs <- factest(diffIRT_fit, se=TRUE)
fs



Resp <- data.frame(resp = x, sbj = 1:nrow(x))
colnames(Resp) <- paste0("Item", 1:10)
tidyr::pivot_longer(data.frame(x), everything())
Rt <- data.frame(resp = rt)
colnames(Rt) <- paste0("Item", 1:10)
Extra <- merge(Resp, Rt, by = "name")

Dmodel_Extra <- function(data = Extra,
                         rt = "rt",
                         resp = "resp", sbj = "sbj",
                         item = "item", model = "Q", priors = NULL,
                         seed = 42, chains = 3, parallel_chains = 1,
                         iter_warmup =  1000,
                         iter_sampling = 2000)


save(file = "dev/Tests.RData")
