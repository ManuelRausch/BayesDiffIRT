rm(list=ls())
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
library(readxl)
Data <-  read_excel("Wirtz_2004.xlsx", na = "")
summary(Data)

AnteilMissingPerPerson <- rowMeans(is.na(Data))
AnteilMissingPerPerson

Data$MissingEinkommen <- is.na(Data$`Zufriedenheit mit Einkommen`)
ttest_MissingEinkommen_by_Leben <-
  t.test(`Zufriedenheit mit dem Leben allgemein` ~ MissingEinkommen, Data )
ttest_MissingEinkommen_by_Leben

Data$MissingBeruf <- is.na(Data$`Zufriedenheit mit Beruf`)
cor(Data$MissingEinkommen, Data$`MissingBeruf`)

library(tidyverse)
library(patchwork)
Data$Versuchsperson <- factor(Data$Versuchsperson)
ggplot(Data, aes(x = `Zufriedenheit mit Einkommen`,
                 y = `Zufriedenheit mit dem Leben allgemein`,
                 fill = Versuchsperson)) +
  geom_point(shape=21) +
  xlim(c(1,11)) + ylim(c(1,11)) +
  theme_minimal() +
  theme(legend.position = "none") +
ggplot(Data, aes(x = `Zufriedenheit mit Beruf`,
                 y = `Zufriedenheit mit dem Leben allgemein`,
                 fill = Versuchsperson)) +
  geom_point(shape=21) +
  xlim(c(1,11)) + ylim(c(1,11)) +
  theme_minimal() +
  theme(legend.position = "none")
