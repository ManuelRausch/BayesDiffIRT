u_ij = rep(rnorm(4, 0, 1), each=100))
dat$math_score = round(50 + dat$e_ij * sqrt(50) + dat$u_ij * sqrt(50))
dat
school_means <- dat %>%
group_by(school) %>%
summarise(mean_math = mean(math_score, na.rm = TRUE)) %>%
arrange(mean_math)
dat$school <- factor(dat$school, levels = school_means$school)
grand_mean <- mean(dat$math_score, na.rm = TRUE)
ggplot(dat, aes(x = 1, y = math_score)) +
geom_jitter(width = 0.12, height = 0, alpha = 0.7, size = 2) +
geom_hline(data = school_means,
aes(yintercept = mean_math),
color = "blue", linewidth = 1) +
geom_hline(yintercept = grand_mean,
linetype = "dashed",
color = "red",
linewidth = 0.8) +
facet_wrap(~ school) +
labs(
x = NULL,
y = "Leistung im Mathetest",
title = "Varianzkomponentenmodell nach Schulen",
subtitle = "Schulen nach mittlerer Matheleistung sortiert"
) +
theme_minimal(base_size = 13) +
theme(
axis.text.x = element_blank(),
axis.ticks.x = element_blank()
)
