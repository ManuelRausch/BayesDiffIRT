?bmrs::prior
?brms::prior
prior <- function(dist, class, coef = NULL, group = NULL) {
structure(
list(
dist = substitute(dist),
class = class,
coef = coef,
group = group
),
class = "BayesDiffIRTPrior"
)
}
prior(class="ability", Normal(0, 1))
