J <- 15
n_j <- 20
N <- J * n_j
# Gruppenvariable
school <- factor(rep(1:J, each = n_j))
# Populationsparameter
gamma_00 <- 50      # Gesamtintercept
tau_00   <- 25      # Varianz zwischen Schulen
sigma2   <- 81      # Varianz innerhalb von Schulen
# Zufällige Schuleffekte
u_0j <- rnorm(J, mean = 0, sd = sqrt(tau_00))
# Individuelle Residuen
e_ij <- rnorm(N, mean = 0, sd = sqrt(sigma2))
# Zielvariable
math_score <- gamma_00 + u_0j[school] + e_ij
# Datensatz
dat_vc <- data.frame(
student_id = 1:N,
school = school,
math_score = round(math_score, 2)
)
J <- 15
n_j <- 20
N <- J * n_j
