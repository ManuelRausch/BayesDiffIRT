library(R.utils)
library(plyr)
library(ggplot2)
library(quickpsy)
# 1) read in data
FileList <-
list.files(
recursive= TRUE,
full.names = TRUE,
pattern = "^ReplDelCul_Eichstätt_[0-9]+_2025.*\\.csv$")
FileList
Data <- ldply(FileList, read.table, header = TRUE,  sep = ",")
Data$ID <-as.numeric(factor(Data$date))
Data$seen <- ifelse(Data$rating > 5, 1, 0)
# 2) Check Data
table(Data$ID)
table(Data$SOAms)
evalq(interaction.plot(soa, ID, seen),
subset(Data, is.finite(target)))
evalq(interaction.plot(soa, ID, cor),
subset(Data, is.finite(target)))
nTrialsPerSubejct <-
plyr::ddply(Data,  ~ ID,summarise,
nTrials = length(seen))
MeanTrials = mean(nTrialsPerSubejct$nTrials)   # 400 trials per h. ~ shorten the pilot to 300 trials!
# 3) exclude training
Data <- Data |> filter(blockNo > 1)
# 4) aggregate
Agg <- ddply(subset(Data,  is.finite(target)),
~ SOAms * ID ,summarise,
Seen = mean(seen),
Accuracy = mean(cor))
AggCorr <- Agg |> Rmisc::summarySEwithin(
measurevar="Accuracy",
withinvars ="SOAms",
idvar = "ID"
)
AggVis <- Agg |> Rmisc::summarySEwithin(
measurevar="Seen",
withinvars ="SOAms",
idvar = "ID"
)
# 5) Plot data
library(patchwork)
p1 <- ggplot(AggCorr, aes(x = as.numeric(SOAms), y = Accuracy)) +
geom_line() + geom_errorbar(aes(ymin = Accuracy-se, ymax=Accuracy+se)) +
geom_point(shape=21, color="black", fill = "blue") +
ylim( c(.5, 1)) + xlab("SOA(ms)") +
ylab("Objective performance") + theme_minimal() +
scale_x_continuous(breaks= 1:6, labels=levels(AggCorr$SOAms))
p2 <- ggplot(AggVis, aes(x = as.numeric(SOAms), y = Seen)) +
geom_line() + geom_errorbar(aes(ymin = Seen-se, ymax=Seen+se)) +
geom_point(shape=21, color="black", fill = "red") +
ylim( c(0, 1)) + xlab("SOA(ms)") +
ylab("Subjective visibility") + theme_minimal() +
scale_x_continuous(breaks= 1:6, labels=levels(AggCorr$SOAms))
p1+p2
# 6) Psychometric function
library(tidyverse)
fit_seen <- Data |>
mutate(myNewSOA = ifelse(is.na(target), 0, SOAms)) |>
# filter(is.finite(target)) |>
group_by(ID, myNewSOA) %>%
dplyr::summarise(
k = sum(seen),
n = n(),
.groups = "drop"
) |>
quickpsy(
x = myNewSOA,
k = k,
n = n,
grouping = .(ID),
log=FALSE,
fun = logistic_fun,
parini = list(c(0, 100), c(0, 1), c(0, .25), c(0, .25)),
guess = TRUE,
lapses = TRUE,              # sensible for masking data
bootstrap = "none",
thresholds=TRUE,
optimization = "DE",# 50% seen = detection threshold
prob = 0.5)
fit_seen
agg_thresholds_vis <- summary(fit_seen$thresholds$thre) # Mittelwert der visibility thresgolds by 5m0 ms
agg_thresholds_vis
t.test(fit_seen$thresholds$thre, mu=50)
PlotPsyFun <-
plot(fit_seen) + theme_minimal() +
scale_x_continuous(breaks = unique(Agg$myNewSOA),
labels = c("no\ntarget", unique(Agg$SOAms)),
name = "SOA [ms]")  +
scale_y_continuous(breaks = seq(0, 1, .25),
labels = seq(0, 100, 25),
name = "Fraction seen trials %")
PlotPsyFun
PlotPsyFun <-
plot(fit_seen) + theme_minimal() +
scale_x_continuous(breaks = unique(Agg$myNewSOA),
labels = c("no\ntarget", unique(Agg$SOAms)),
name = "SOA [ms]")  +
scale_y_continuous(breaks = seq(0, 1, .25),
labels = seq(0, 100, 25),
name = "Fraction seen trials %")
fit_corr
fit_corr <- Data |>
filter(!is.na(target)) %>%
group_by(ID, SOAms) %>%
dplyr::summarise(
k = sum(cor),
n = n(),
.groups = "drop"
) |>
quickpsy(
x = SOAms,
k = k,
n = n,
grouping = .(ID),
fun = logistic_fun,
parini = list(c(0, 100), c(0, 1), c(.45, .55), c(0, .1)),
guess = TRUE,
lapses = TRUE,              # sensible for masking data
bootstrap = "none",
thresholds=TRUE,
#    B = 1000,
prob = 0.75                  # 50% seen = detection threshold
)
fit_corr
PlotPsyFunCorr <-
plot(fit_corr) + theme_minimal() +
scale_x_continuous(breaks = unique(Agg$SOAms),
labels = unique(Agg$SOAms),
name = "SOA [ms]",
limits = c(0, 100))  +
scale_y_continuous(breaks = seq(.5, 1, .25),
labels = seq(50, 100, 25),
name = "Fraction correct trials %"
# limits = c(.4, 1)
) +
ggtitle("Objective performance")
PlotPsyFunCorr + PlotPsyFun
t.test(fit_corr$thresholds$thre, mu=50)
save.image("AnalyzePilotV5.RData")
PlotPsyFunCorr <-
plot(fit_corr) + theme_minimal() +
scale_x_continuous(breaks = unique(Agg$SOAms),
labels = unique(Agg$SOAms),
name = "SOA [ms]",
limits = c(0, 100))  +
scale_y_continuous(breaks = seq(.5, 1, .25),
labels = seq(50, 100, 25),
name = "Fraction correct trials %"
# limits = c(.4, 1)
) +
ggtitle("Objective performance")
PlotPsyFunCorr + PlotPsyFun
cor.test(fit_seen$thresholds$thre,
fit_corr$thresholds$thre)
fit_seen
rm(list=ls())
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
